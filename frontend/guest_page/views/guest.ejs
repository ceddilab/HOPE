<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Guest Page - D.D.C.A</title>
  <link rel="stylesheet" href="/css/guest.css" />
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="brand">D.D.C.A</div>
      <div class="nav-links">
        <a href="/home">Home</a>
        <a href="/AboutUs">About Us</a>
        <a href="/login">Login</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="hero">
    <div class="hero-content">
      <h1>Welcome to the D.D.C.A Guest Page</h1>
      <p>Explore and Build Optimised Disaster Management System without logging in</p>
    </div>
  </header>

  <section class="main-content">
    <div class="cards">
  
      <!-- Card 1 -->
      <div class="card">
        <div class="card-icon">
          <img src="/img/depot-location.svg" alt="Depot Icon" />
        </div>
        <h3>SERA</h3>
        <h3>(Safe Emergency Response Alliance)</h3>
        <p>Identify the ideal depot location for efficient supply delivery and emergency coverage.</p>
        <a href="/clustering" class="card-link-btn">Check Now</a>
      </div>
  
      <!-- Card 2 -->
      <div class="card">
        <div class="card-icon">
          <img src="/img/route-icon.svg" alt="Route Icon" />
        </div>
        <h3>NET</h3>
        <h3>(Navigation & Emergency Tracking)</h3>
        <p>Quickly calculate the best route to the nearest depot from your current location.</p>
        <a href="/routes" class="card-link-btn">Find Route</a>
      </div>
  
      <!-- Card 3 -->
      <div class="card">
        <div class="card-icon">
          <img src="/img/area-info.svg" alt="Area Info Icon" />
        </div>
        <h3>ECHO</h3>
        <h3>(Emergency Coordination & Help Organization)</h3>
        <p>Access detailed geographic data to improve planning and disaster response.</p>
        <a href="/area-info" class="card-link-btn">Explore Area</a>
      </div>
      <!-- Card 4 -->
      <div class="card">
        <div class="card-icon">
          <img src="/img/area-info.svg" alt="Area Info Icon" />
        </div>
        <h3>HEAL </h3>
        <h3>(Humanitarian Emergency Aid & Logistics) </h3>
        <p>Access detailed geographic data to improve planning and disaster response.</p>
        <a href="/first-aid" class="card-link-btn">Explore Area</a>
      </div>
  
    </div>
  </section>
  

  <!-- Footer -->
  <footer>
    <p>© 2025 D.D.C.A All rights reserved.</p>
  </footer>

</body>
</html>
